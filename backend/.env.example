DATABASE_URL=postgresql://resume_user:resume_password@localhost:5432/resume_eval
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

COSINE_MATCH_THRESHOLD=0.70
COSINE_STRONG_THRESHOLD=0.85
SIMHASH_DUPLICATE_THRESHOLD=3

DEFAULT_WEIGHT_PROJECTS=50
DEFAULT_WEIGHT_SKILLS=30
DEFAULT_WEIGHT_EDUCATION=20

EMBEDDING_MODEL=all-MiniLM-L6-v2
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

# LLM scoring (leave LLM_API_KEY blank to use TF-IDF scorer instead)
# OpenAI:       LLM_BASE_URL=https://api.openai.com/v1       LLM_MODEL=gpt-4o-mini
# Anthropic:    LLM_BASE_URL=https://api.anthropic.com/v1    LLM_MODEL=claude-3-5-haiku-20241022
# Groq:         LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3-8b-8192
# Together AI:  LLM_BASE_URL=https://api.together.xyz/v1     LLM_MODEL=mistralai/Mixtral-8x7B
# Ollama local: LLM_BASE_URL=http://localhost:11434/v1        LLM_MODEL=llama3
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT=30

# SMTP outbound email (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=careers@yourcompany.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=careers@yourcompany.com

# IMAP email ingestion (leave IMAP_HOST blank to disable)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=careers@yourcompany.com
IMAP_PASSWORD=your_imap_password
IMAP_SSL=true
IMAP_POLL_INTERVAL=60
